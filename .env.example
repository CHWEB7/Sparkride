# Copy this file to .env and fill in your values
# cp .env.example .env   (or copy manually on Windows)
#
# If Supabase is connected to Vercel via the integration, pull vars locally:
#   npx vercel link
#   npx vercel env pull .env
# Then add the app-specific secrets below (JWT, driver, Google Maps).

# --- Supabase (auto-set by Vercel ↔ Supabase integration) ---
# Prisma runtime: pooled connection (Vercel serverless)
POSTGRES_PRISMA_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Prisma migrations / db push: direct connection (port 5432)
POSTGRES_URL_NON_POOLING="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
# Server only — synced by integration; never expose to the browser
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# --- App secrets (add these yourself — not from Supabase integration) ---
# Required for daily MFA cookie/code signing (customers)
JWT_SECRET="change-me-to-a-long-random-string"

# Driver MFA: enable TOTP in Supabase Dashboard → Authentication → Multi-Factor
# One-time sync secret for POST /api/admin/sync-driver-auth
ADMIN_SYNC_SECRET="change-me-long-random-string"

# Daily MFA verification emails (Resend — free tier: 100/day)
# Sign up at https://resend.com and create an API key
RESEND_API_KEY=""
# Optional: use after verifying your domain in Resend
# MFA_EMAIL_FROM="Sparkride <verify@yourdomain.com>"
DRIVER_EMAIL="driver@sparkride.co.uk"
DRIVER_PASSWORD="driver123"

# Google Maps — enable "Places API (New)" in Google Cloud Console
GOOGLE_MAPS_API_KEY=""

# Optional: canonical production URL for Supabase email redirects
# NEXT_PUBLIC_SITE_URL="https://sparkride-umber.vercel.app"
# NEXT_PUBLIC_APK_URL="https://example.com/sparkride.apk"

# --- Square payments (hosted checkout via Square Connect) ---
# See docs/square-payments.md for dashboard setup (OAuth redirect + webhooks).
SQUARE_APPLICATION_ID=""
# OAuth Application secret — from Square → OAuth tab (sandbox-sq0csp-…). NOT the Credentials tab access token.
SQUARE_APPLICATION_SECRET=""
SQUARE_WEBHOOK_SIGNATURE_KEY=""
SQUARE_ENVIRONMENT="sandbox"
SQUARE_OAUTH_STATE_SECRET="change-me-long-random-string"
SQUARE_TOKEN_ENCRYPTION_KEY="change-me-long-random-string"

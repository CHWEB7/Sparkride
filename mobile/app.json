{
  "expo": {
    "name": "Sparkride",
    "slug": "sparkride-mobile",
    "version": "1.0.6",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "sparkride",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#6a68de"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "co.uk.sparkride.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#6a68de"
      },
      "package": "co.uk.sparkride.app",
      "versionCode": 4
    },
    "plugins": ["expo-router"],
    "extra": {
      "eas": {
        "projectId": "4325bf6c-d50f-489b-9fe8-4beadf074c4d"
      }
    }
  }
}

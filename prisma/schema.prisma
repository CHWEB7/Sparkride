generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model Customer {
  id                 String               @id
  email              String               @unique
  name               String?
  phone              String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  bookings           Booking[]
  savedBookingDetails SavedBookingDetails[]
}

model CustomerMfaSession {
  userId        String    @id
  validDate     String
  expiresAt     DateTime
  lastOtpSentAt DateTime?
  otpHash       String?
  otpExpiresAt  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Driver {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String
  phone         String?
  vehicleLabel  String?
  vehicleType   VehicleType @default(SALOON)
  maxSeats      Int       @default(4)
  bookable      Boolean   @default(false)
  createdAt     DateTime  @default(now())
  bookings      Booking[]
}

model SavedBookingDetails {
  id             String      @id @default(cuid())
  customerId     String
  customer       Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  label          String
  serviceType    ServiceType @default(AIRPORT_TRANSFER)
  journeyType    JourneyType @default(SINGLE)
  tripType       TripType    @default(TO_AIRPORT)
  airportCode    String?
  pickupAddress  String
  dropoffAddress String
  passengers     Int         @default(1)
  luggage        Int         @default(1)
  vehicleType    VehicleType @default(SALOON)
  driverId       String?
  notes          String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model Booking {
  id                 String        @id @default(cuid())
  reference          String        @unique
  status             BookingStatus @default(PENDING)
  serviceType        ServiceType   @default(AIRPORT_TRANSFER)
  journeyType        JourneyType   @default(SINGLE)
  tripType           TripType
  airportCode        String?
  airportName        String?
  pickupAddress      String
  dropoffAddress     String
  pickupDate         DateTime
  returnPickupDate   DateTime?
  passengers         Int           @default(1)
  luggage            Int           @default(1)
  vehicleType        VehicleType   @default(SALOON)
  customerName       String
  customerEmail      String
  customerPhone      String
  flightNumber       String?
  returnFlightNumber String?
  notes              String?
  estimatedPrice     Float?
  driverId           String?
  driver             Driver?       @relation(fields: [driverId], references: [id])
  customerId         String?
  customer           Customer?     @relation(fields: [customerId], references: [id])
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
}

enum ServiceType {
  AIRPORT_TRANSFER
  PRE_BOOKED
}

enum JourneyType {
  SINGLE
  RETURN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  EN_ROUTE
  COMPLETED
  CANCELLED
}

enum TripType {
  TO_AIRPORT
  FROM_AIRPORT
}

enum VehicleType {
  SALOON
  ESTATE
  MPV
  EXECUTIVE
}
